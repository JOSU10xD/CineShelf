# CineShelf Render.com Environment Variables Template
# Copy these keys into the Render.com Dashboard (Environment -> Import from .env)
# Replace placeholder values with your actual credentials from your local gitignored `server/.env` file.

PORT=8080
NODE_ENV=production
TASTE_PROVIDER=openrouter
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
RECOMM_CACHE_TTL_HOURS=12

# Replace these with your actual credentials:
TMDB_API_KEY=your_tmdb_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Firebase Service Account Base64 string (generate by converting service account JSON to base64):
FIREBASE_SERVICE_ACCOUNT_BASE64=your_firebase_service_account_base64_here

# AI Model Selection (Optional, defaults to openrouter/free):
# To get high quality outputs, top up your OpenRouter account and set a paid model here:
# OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
